# ─────────────────────────────────────────────────────────────────────────────
# SiteGrade — Environment Variables Template
# Copy this file to .env.local (never commit .env.local)
# All variables are required unless marked [optional]
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key — safe to expose in browser
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose in browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for verifying Supabase tokens — Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Connection pooler URL (port 6543) — used by Prisma at runtime
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection URL (port 5432) — used by Prisma for migrations
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# REST URL from Upstash console → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# REST token from Upstash console
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe dashboard → Products → your product → Prices
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# Publishable key (safe for browser) — used in apps/web
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key from platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────────────────────
# API key from resend.com → API Keys
RESEND_API_KEY=re_...

# From address — must be a verified domain in Resend
RESEND_FROM_EMAIL=noreply@sitegade.app

# ── App URLs ──────────────────────────────────────────────────────────────────
# Production URL of the web app (no trailing slash)
APP_URL=https://sitegade.app
NEXT_PUBLIC_APP_URL=https://sitegade.app

# Production URL of the API service (Railway)
NEXT_PUBLIC_API_URL=https://api.sitegade.app

# ── Next.js (apps/web only) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Worker (apps/worker only) ─────────────────────────────────────────────────
# Number of concurrent audit jobs (default: 3)
WORKER_CONCURRENCY=3

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
